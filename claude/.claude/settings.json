{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  },
  "cleanupPeriodDays": 7,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(jq *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(source activate *)",
      "Bash(conda activate *)",
      "mcp__prompt_builder__generate_prompt",
      "Bash(python -m pytest tests/ -v --tb=short)",
      "Bash(python -m pytest tests/ -q --tb=short)",
      "Bash(python:*)",
      "Bash(echo \"EXIT_CODE=$?\")",
      "Bash(python -c \":*)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Read(//data/blake/prompt-builder-improves/mcp-prompt-builder/**)",
      "Bash(done)",
      "Bash(python3 -c \":*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(source /home/blake/miniconda3/etc/profile.d/conda.sh)",
      "Bash(.venv/Scripts/python -m pytest -v)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/credentials*)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -f *)",
      "Bash(rm -fr *)",
      "Bash(rmdir *)",
      "Bash(find * -delete *)",
      "Bash(find * -exec rm *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod a+rwx *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(diskpart *)",
      "Bash(format.com *)",
      "Bash(bcdedit *)",
      "Bash(shutdown *)",
      "Bash(taskkill *)",
      "Bash(wmic *)",
      "Bash(msiexec *)",
      "Bash(rundll32 *)",
      "Bash(schtasks /delete *)",
      "Bash(schtasks /create *)",
      "Bash(sc delete *)",
      "Bash(sc stop *)",
      "Bash(sc config *)",
      "Bash(net stop *)",
      "Bash(net start *)",
      "Bash(net user *)",
      "Bash(reg delete *)",
      "Bash(reg add *)",
      "Bash(reg import *)",
      "Bash(netsh *)",
      "Bash(icacls * /grant *)",
      "Bash(icacls * /reset *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git stash drop *)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/notify-permission.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "russian",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "low",
  "autoUpdatesChannel": "stable",
  "plansDirectory": "./docs/plans",
  "preferredNotifChannel": "terminal_bell"
}