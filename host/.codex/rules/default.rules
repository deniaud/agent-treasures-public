prefix_rule(pattern=["du"], decision="allow")
prefix_rule(pattern=["date"], decision="allow")
prefix_rule(pattern=["mkdir"], decision="allow")
prefix_rule(pattern=["chmod"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["test"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "rev-parse", "HEAD"], decision="allow")
prefix_rule(pattern=["git", "worktree", "list"], decision="allow")
prefix_rule(pattern=["go", "test", "./...", "-run"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "set -a; source conf/systemd/.env; set +a; export LOG_LEVEL=error; timeout 30s go run main.go"], decision="allow")
prefix_rule(pattern=["go", "test", "./billing", "-run"], decision="allow")
prefix_rule(pattern=["command", "-v", "docker"], decision="allow")
prefix_rule(pattern=["node", "--test", "server/test/app.test.js"], decision="allow")
prefix_rule(pattern=["printf", "\\n--- HMR ---\\n"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["printf", "\\n--- README ---\\n"], decision="allow")
